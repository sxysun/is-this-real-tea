{
  "configurable_urls": [
    {
      "name": "env_var_url_in_compose",
      "pattern": "\\$\\{[A-Z_]*(URL|ENDPOINT|HOST|SERVER|BASE|API|GATEWAY)[A-Z_]*\\}",
      "glob": "*.y*ml",
      "description": "Environment variable controlling a URL in compose/YAML"
    },
    {
      "name": "llm_base_url",
      "pattern": "LLM_BASE_URL|OPENAI_BASE_URL|OPENAI_API_BASE",
      "description": "Configurable LLM endpoint"
    },
    {
      "name": "api_url_env",
      "pattern": "API_URL|API_ENDPOINT|BACKEND_URL|SERVICE_URL",
      "description": "Generic configurable API endpoint"
    },
    {
      "name": "webhook_callback",
      "pattern": "WEBHOOK_URL|CALLBACK_URL|REDIRECT_URL|NOTIFY_URL",
      "description": "Configurable webhook/callback URL"
    },
    {
      "name": "mock_api_url",
      "pattern": "MOCK_API_URL|MOCK_URL|MOCK_ENDPOINT",
      "description": "Mock API URL (potential exfiltration in production)"
    }
  ],
  "external_network_calls": [
    {
      "name": "http_requests",
      "pattern": "requests\\.(get|post|put|patch|delete)|urllib\\.request|fetch\\(|axios\\.|http\\.(get|post)|HttpClient",
      "description": "HTTP client calls"
    },
    {
      "name": "websocket",
      "pattern": "WebSocket|ws://|wss://|socket\\.connect",
      "description": "WebSocket connections"
    },
    {
      "name": "dns_resolution",
      "pattern": "dns\\.resolve|getaddrinfo|nslookup",
      "description": "DNS resolution calls"
    }
  ],
  "attestation_code": [
    {
      "name": "quote_verification",
      "pattern": "verify.*quote|quote.*verify|tdx.*report|attestation.*verify",
      "description": "TDX quote verification code"
    },
    {
      "name": "attestation_endpoint",
      "pattern": "/attestation|certFingerprint|app_compose",
      "description": "Attestation-related endpoints"
    },
    {
      "name": "tappd_client",
      "pattern": "tappd|TappdClient|deriveKey|tdxQuote",
      "description": "dstack guest SDK usage"
    }
  ],
  "red_flags": [
    {
      "name": "known_issue_comments",
      "pattern": "HACK|FIXME|XXX|UNSAFE|known.issue|temporary.workaround",
      "description": "Developer-acknowledged issues"
    },
    {
      "name": "hash_mismatch_accept",
      "pattern": "skip.*verif|ignore.*hash|allow.*mismatch|disable.*check",
      "description": "Verification bypass code"
    },
    {
      "name": "dev_fallback",
      "pattern": "if.*dev|if.*debug|if.*test.*mode|fallback.*insecure|INSECURE_SKIP",
      "description": "Development/debug fallbacks that may persist in production"
    },
    {
      "name": "eval_exec",
      "pattern": "\\beval\\(|\\bexec\\(|Function\\(|child_process\\.exec",
      "description": "Dynamic code execution"
    },
    {
      "name": "hardcoded_secrets",
      "pattern": "sk-[a-zA-Z0-9]{20,}|AKIA[A-Z0-9]{16}|ghp_[a-zA-Z0-9]{36}",
      "description": "Hardcoded API keys or secrets"
    }
  ],
  "build_reproducibility": [
    {
      "name": "pinned_digest",
      "pattern": "@sha256:[a-f0-9]{64}",
      "description": "Pinned image digest"
    },
    {
      "name": "source_date_epoch",
      "pattern": "SOURCE_DATE_EPOCH",
      "description": "Reproducible build timestamp"
    },
    {
      "name": "lockfile",
      "pattern": "package-lock\\.json|yarn\\.lock|poetry\\.lock|Pipfile\\.lock|Cargo\\.lock|go\\.sum",
      "glob": "",
      "description": "Dependency lockfile presence"
    }
  ],
  "secrets_storage": [
    {
      "name": "kms_usage",
      "pattern": "deriveKey|kms.*derive|dstack.*key|TappdClient",
      "description": "KMS/key derivation usage"
    },
    {
      "name": "env_secret_patterns",
      "pattern": "SECRET|PRIVATE_KEY|PASSWORD|TOKEN|API_KEY|CREDENTIALS",
      "description": "Secret-related environment variable references"
    },
    {
      "name": "encrypted_storage",
      "pattern": "encrypt|decrypt|cipher|AES|ChaCha|sealed",
      "description": "Encryption/decryption code"
    }
  ],
  "smart_contracts": [
    {
      "name": "appauth_contract",
      "pattern": "AppAuth|IAppAuth|addComposeHash|addDevice|isAppAllowed",
      "description": "AppAuth contract interaction"
    },
    {
      "name": "contract_address",
      "pattern": "0x[a-fA-F0-9]{40}",
      "description": "Ethereum contract addresses"
    },
    {
      "name": "onchain_verification",
      "pattern": "ethers|web3|viem|basescan|etherscan",
      "description": "On-chain interaction libraries"
    }
  ]
}
